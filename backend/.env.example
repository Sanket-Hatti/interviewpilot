# Copy this file to .env and fill in your real values
# NEVER commit .env to Git

# Flask
FLASK_ENV=development

# Database — get connection string from neon.tech
DATABASE_URL=postgresql://username:password@hostname/dbname?sslmode=require

# JWT — generate a strong random string (e.g. python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Gemini AI — get from aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# CORS — frontend origin (Vite default)
CORS_ORIGINS=http://localhost:5173
